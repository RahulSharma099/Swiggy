# Database Configuration
# PostgreSQL connection string for the project management system
DATABASE_URL=postgresql://user:password@localhost:5432/pms_dev?schema=public

# API Configuration
# Port for the REST API server
PORT=3000

# Node environment (development, staging, production)
NODE_ENV=development

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# WebSocket Configuration
# Port for WebSocket server for real-time updates
WEBSOCKET_PORT=3001

# Redis Configuration
# Used for Pub/Sub messaging and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT Configuration
# Secret key for JWT token signing
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiration time
JWT_EXPIRES_IN=7d

# Email Configuration
# SMTP server details for sending notifications
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@pms.local

# Monitoring & Logging
# JSON or plain text format
LOG_FORMAT=json

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Feature Flags
# Control feature availability
FEATURE_REAL_TIME_UPDATES=true
FEATURE_WORKFLOW_ENGINE=true
FEATURE_NOTIFICATIONS=true
