// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================================
// BASE MODELS
// ============================================================================

/// User model for authentication and workspace membership
model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    workspaceMembers WorkspaceMember[]
    projectMembers   ProjectMember[]
    issues           Issue[]           @relation("issueReporter")
    assignedIssues   Issue[]           @relation("issueAssignee")
    comments         Comment[]
    activityLogs     ActivityLog[]

    @@index([email])
}

/// Workspace model for multi-tenancy isolation
model Workspace {
    id        String   @id @default(cuid())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    members  WorkspaceMember[]
    projects Project[]

    @@index([id])
}

/// WorkspaceMember model for user workspace membership
model WorkspaceMember {
    id          String   @id @default(cuid())
    workspaceId String
    userId      String
    role        String   @default("member") // owner, lead, member, viewer
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([workspaceId, userId])
    @@index([workspaceId])
    @@index([userId])
}

/// Project model
model Project {
    id          String   @id @default(cuid())
    workspaceId String
    name        String
    description String?
    keyPrefix   String   @default("PROJ") // e.g., "BUG", "FEAT"
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    members   ProjectMember[]
    issues    Issue[]
    sprints   Sprint[]

    @@unique([workspaceId, id])
    @@index([workspaceId])
}

/// ProjectMember model for project-level access
model ProjectMember {
    id        String   @id @default(cuid())
    projectId String
    userId    String
    role      String   @default("member") // owner, lead, dev, viewer
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])
    @@index([projectId])
    @@index([userId])
}

/// Sprint model for agile sprints
model Sprint {
    id        String   @id @default(cuid())
    projectId String
    name      String
    startDate DateTime
    endDate   DateTime
    status    String   @default("active") // active, completed, archived
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    issues  Issue[]

    @@index([projectId])
    @@index([status])
}

/// Issue model - core entity
model Issue {
    id          String    @id @default(cuid())
    projectId   String
    parentId    String? // for hierarchies: story → sub-task
    epicId      String? // for epic relationships
    sprintId    String? // for sprint assignment
    title       String
    description String?
    type        String    @default("task") // story, task, bug, epic, sub-task
    status      String    @default("open") // open, in-progress, review, done, closed
    priority    Int       @default(2) // 1 (lowest) to 5 (highest)
    storyPoints Int? // nullable for bugs/tasks
    reporterId  String
    assigneeId  String?
    version     Int       @default(0) // for optimistic locking
    metadata    Json      @default("{}") // for custom fields
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime? // soft delete support

    // Relations
    project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
    sprint     Sprint?       @relation(fields: [sprintId], references: [id], onDelete: SetNull)
    reporter   User          @relation("issueReporter", fields: [reporterId], references: [id], onDelete: Cascade)
    assignee   User?         @relation("issueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
    comments   Comment[]
    activities ActivityLog[]
    watchers   Watcher[]

    @@unique([projectId, id])
    @@index([projectId])
    @@index([sprintId])
    @@index([status])
    @@index([assigneeId])
    @@index([reporterId])
    @@index([type])
    @@index([deletedAt])
}

/// Comment model for issue discussions
model Comment {
    id        String   @id @default(cuid())
    issueId   String
    authorId  String
    content   String
    mentions  Json     @default("[]") // array of @mentioned user IDs
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
    author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

    @@index([issueId])
    @@index([authorId])
}

/// ActivityLog model for audit trail
model ActivityLog {
    id            String   @id @default(cuid())
    issueId       String
    workspaceId   String
    actionType    String // created, updated, status_changed, commented, deleted
    changedFields Json     @default("{}") // delta of what changed
    actorId       String
    createdAt     DateTime @default(now())

    // Relations
    issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
    actor User  @relation(fields: [actorId], references: [id], onDelete: Cascade)

    @@index([issueId])
    @@index([workspaceId])
    @@index([createdAt])
}

/// Watcher model for issue notifications
model Watcher {
    id        String   @id @default(cuid())
    issueId   String
    userId    String
    createdAt DateTime @default(now())

    // Relations
    issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

    @@unique([issueId, userId])
    @@index([issueId])
}

/// IssueStatusTransition - workflow definitions
model IssueStatusTransition {
    id         String   @id @default(cuid())
    projectId  String
    fromStatus String
    toStatus   String
    conditions Json     @default("[]") // conditions that must be met
    actions    Json     @default("[]") // actions to execute
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([projectId])
    @@index([fromStatus])
}
