{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@pms/shared": ["../shared/src"],
      "@pms/shared/*": ["../shared/src/*"],
      "@pms/database": ["../database/src"],
      "@pms/database/*": ["../database/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.test.ts", "**/__tests__"]
}
