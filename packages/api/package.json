{
  "name": "@pms/api",
  "version": "0.1.0",
  "description": "REST API server",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node dist/server.js\" --project tsconfig.json",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@pms/shared": "*",
    "@pms/database": "*",
    "express": "^4.18.0",
    "zod": "^3.22.0",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "redis": "^4.6.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsc-watch": "^6.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.0"
  }
}
