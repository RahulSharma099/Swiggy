            "url": {
              "raw": "{{baseUrl}}/workspaces/{{workspaceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "workspaces",
                "{{workspaceId}}"
              ]
            }
          }
        }
      ]
