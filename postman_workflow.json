  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "API Health Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response has success property', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('success');",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "});",
                  "",
                  "pm.test('✅ Response has message', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message');",
                  "  pm.expect(jsonData.message).to.include('healthy');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📋 Workspace Management",
      "item": [
        {
          "name": "Create Workspace",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = new Date().getTime();",
                  "const workspaceName = `Workspace-${timestamp}`;",
                  "pm.environment.set('workspaceName', workspaceName);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('✅ Response has data with id', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('id');",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "});",
                  "",
                  "pm.test('✅ Save workspace ID', function () {",
                  "  const jsonData = pm.response.json();",
                  "  const workspaceId = jsonData.data.id;",
                  "  pm.environment.set('workspaceId', workspaceId);",
                  "  console.log('Workspace created:', workspaceId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{workspaceName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/workspaces",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "workspaces"
              ]
            }
          }
        },
        {
          "name": "Get All Workspaces",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response is array', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.be.an('array');",
                  "  pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/workspaces",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "workspaces"
              ]
            }
          }
        },
        {
          "name": "Get Workspace by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response has workspace data', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.have.property('id');",
                  "  pm.expect(jsonData.data.id).to.equal(pm.environment.get('workspaceId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/workspaces/{{workspaceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "workspaces",
                "{{workspaceId}}"
              ]
            }
          }
        },
        {
          "name": "Update Workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Workspace name updated', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.have.property('name');",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
