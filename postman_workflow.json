  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "workspaceName",
      "value": ""
    },
    {
      "key": "workspaceId",
      "value": ""
    },
    {
      "key": "projectName",
      "value": ""
